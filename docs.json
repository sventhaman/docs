        "icon": "wallet",
        "pages": [
          "client-billing/connect-stripe",
          "client-billing/bill-clients"
        ]
      },
      {
        "group": "Account & billing",
        "icon": "credit-card",
        "pages": [
          "billing/subscription",
          "billing/usage",
          "billing/add-credits",
          "billing/trial"
        ]

{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Brandless.",
  "description": "Guides for running your white-label AI voice and chat agent business on Brandless.",
  "colors": {
    "primary": "#171717",
    "light": "#a3a3a3",
    "dark": "#171717"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }

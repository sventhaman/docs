  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "index",
          "getting-started/quickstart",
          "getting-started/plans",
          "getting-started/key-terms"
        ]
      },
      {
        "group": "Your brand",
        "icon": "palette",
        "pages": [
          "your-brand/subdomain",
          "your-brand/custom-domain",
          "your-brand/custom-email"
        ]
      },
      {
        "group": "Clients",
        "icon": "users",
        "pages": [
          "clients/create",
          "clients/assign-agent"
        ]
      },
      {
        "group": "Building agents",
        "icon": "bot",
        "pages": [
          "agents/create",
          "agents/system-prompt",
          "agents/voice",
          "agents/playground",
          "agents/publish"
        ]
      },
      {
        "group": "Chat & embedding",
        "icon": "code",
        "pages": [
          "chat/embed"
        ]
      },
      {
        "group": "Calendar",
        "icon": "calendar",
        "pages": [
          "calendar/calendar",
          "calendar/booking-page"
        ]
      },
      {
